# =============================================================================
# Shared detection ruleset - Cooperative Cloud IDS Framework
# -----------------------------------------------------------------------------
# These are Snort/Suricata-compatible signatures modelled on the Emerging
# Threats Open ruleset, scoped to the three attack categories evaluated in the
# study: DoS (SYN flood), SQL Injection, and SSH Brute Force.
#
# To use the FULL Emerging Threats Open ruleset instead, run:
#   ./scripts/fetch_rules.sh
# which downloads emerging-all.rules into this directory.
#
# SID range 1000000+ is reserved for local rules.
# =============================================================================

# ----------------------------------------------------------------------------
# 1. Denial of Service - TCP SYN flood (Hping3 -S --flood -p 80)
# DVWA listens on port 80 inside the container; attacks against the target's
# ids_net IP directly (not the host-published port) must target 80.
# ----------------------------------------------------------------------------
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"COOP-IDS DoS TCP SYN flood detected"; flags:S,12; flow:stateless; threshold:type both, track by_dst, count 100, seconds 1; classtype:attempted-dos; sid:1000001; rev:2;)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"COOP-IDS DoS high-rate SYN to service port"; flags:S; threshold:type threshold, track by_src, count 200, seconds 2; classtype:attempted-dos; sid:1000002; rev:1;)

# ----------------------------------------------------------------------------
# 2. SQL Injection - against DVWA (SQLMap payload patterns)
# ----------------------------------------------------------------------------
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"COOP-IDS SQL Injection UNION SELECT"; flow:to_server,established; http.uri; content:"union"; nocase; content:"select"; nocase; distance:0; classtype:web-application-attack; sid:1000010; rev:2;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"COOP-IDS SQL Injection boolean/tautology (OR 1=1)"; flow:to_server,established; http.uri; content:"or"; nocase; pcre:"/or\s+1\s*=\s*1/i"; classtype:web-application-attack; sid:1000011; rev:2;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"COOP-IDS SQL Injection comment/probe chars"; flow:to_server,established; http.uri; pcre:"/(\%27|\')(\s)*(--|\#|\/\*)/i"; classtype:web-application-attack; sid:1000012; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"COOP-IDS SQLMap user-agent"; flow:to_server,established; http.user_agent; content:"sqlmap"; nocase; classtype:web-application-attack; sid:1000013; rev:1;)

# ----------------------------------------------------------------------------
# 3. SSH Brute Force - against the target SSH daemon (Hydra)
# ----------------------------------------------------------------------------
alert tcp $EXTERNAL_NET any -> $SSH_SERVERS 22 (msg:"COOP-IDS SSH brute force - repeated connection attempts"; flow:to_server; flags:S; threshold:type both, track by_src, count 5, seconds 30; classtype:attempted-admin; sid:1000020; rev:2;)

alert ssh $EXTERNAL_NET any -> $SSH_SERVERS 22 (msg:"COOP-IDS SSH brute force - rapid auth sessions"; flow:to_server,established; threshold:type both, track by_src, count 5, seconds 60; classtype:attempted-admin; sid:1000021; rev:1;)
